# Apex Infinite CLI - provider settings
# Copy this file to .env and fill in your local values:
#   cp .env.example .env
#
# These values are referenced by config.yaml using ${ENV_VAR} syntax.
# Agent settings (binary, flags, model effort) are in config.yaml, not here.

# Local Ollama provider
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen2.5-coder:7b-instruct-q4_K_M

# Local Ollama Docker deployment
OLLAMA_DOCKER_PROJECT=apex-infinite-ollama
OLLAMA_DOCKER_CONTAINER=apex-infinite-ollama
OLLAMA_DOCKER_IMAGE=ollama/ollama:latest
OLLAMA_DOCKER_VOLUME=apex-infinite-ollama
OLLAMA_DOCKER_BIND_HOST=127.0.0.1
OLLAMA_DOCKER_GPU=auto
OLLAMA_DOCKER_WAIT_SECONDS=180
OLLAMA_DOCKER_PROGRESS=plain
OLLAMA_KEEP_ALIVE=24h
OLLAMA_CHAT_CHECK_TIMEOUT=90

# Provider preflight and live Ollama tests
APEX_INFINITE_PROVIDER_CHECK_TIMEOUT=90
APEX_INFINITE_LIVE_OLLAMA=0

# Hosted providers
XAI_API_KEY=xai-your-key-here
OPENAI_API_KEY=sk-your-key-here
