# Apex Infinite CLI - provider settings
# Copy this file to .env and fill in your local values:
#   cp .env.example .env
#
# These values are referenced by config.yaml using ${ENV_VAR} syntax.
# Agent settings (binary, flags, model effort) are in config.yaml, not here.

# Local Ollama provider
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen2.5:7b

# Provider preflight and live Ollama tests
APEX_INFINITE_PROVIDER_CHECK_TIMEOUT=10
APEX_INFINITE_LIVE_OLLAMA=0

# Hosted providers
XAI_API_KEY=xai-your-key-here
OPENAI_API_KEY=sk-your-key-here
